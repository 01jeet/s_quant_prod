APP_PORT = 5010
HOST=localhost

# ==============================================================================
#  DOCKER 🚀 HIGH PRIORITY: SECURITY & ACCESS (Edit these first)
# ==============================================================================

# --- Valkey ---
VALKEY_PASSWORD=only_my_test123
VALKEY_PORT=6379
# Redis Commander GUI Port
REDIS_COMMANDER_PORT=8081

FLOWER_PORT=5555
# --- NATS ---
NATS_USER=nats_user
NATS_PASSWORD=nats_password
NATS_PORT=4222
NATS_UIPORT=8222

# --- Centrifugo ---
CENTRIFUGO_TOKEN_HMAC_SECRET=my_secret123
CENTRIFUGO_API_KEY=my_api_key
CENTRIFUGO_ADMIN_PASSWORD=password
CENTRIFUGO_ADMIN_SECRET=secret
CENTRIFUGO_PORT=8000

# --- Infra PostgreSQL ---
INFRA_POSTGRES_USER=app_user
INFRA_POSTGRES_PASSWORD=app_password
INFRA_POSTGRES_DB=app_db
INFRA_POSTGRES_PORT=5432

# --- pgAdmin ---
PGADMIN_SERVER_HOST=infra-postgres
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# --- Clickhouse ---
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default
CLICKHOUSE_DB=market
CLICKHOUSE_PORT=8123
CLICKHOUSE_PORT_UI=9000

# --- Temporal ---

# --- Temporal PostgreSQL ---
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_PORT=5431

# ==============================================================================
# ⚙️ APPLICATION SETTINGS (Project specific)
# ==============================================================================
TZ=Asia/Kolkata
DEFAULT_NAMESPACE=S_QUANT
TEMPORAL_UI_CORS=http://localhost:3000
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
BIND_IP=0.0.0.0
ELASTICSEARCH_PORT=9200
# ==============================================================================
# 🛠️ SYSTEM DEFAULTS (Rarely edited)
# ==============================================================================
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=15s

# Paths for config volumes (Relative to docker-compose.yml)
CENTRIFUGO_CONFIG_PATH=./centrifugo_config/centrifugo_config.json
PGADMIN_SERVER_CONFIG_PATH=./pgadmin_config/servers.json
